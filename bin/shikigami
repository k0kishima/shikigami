#!/bin/bash

# Shikigami - On-demand AI Agent Orchestrator for Software Development
# https://github.com/your-org/shikigami

set -e

# Determine SHIKIGAMI_HOME
if [ -z "$SHIKIGAMI_HOME" ]; then
  # Default to the directory containing this script's parent
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  SHIKIGAMI_HOME="$(dirname "$SCRIPT_DIR")"
fi

MIN_CLAUDE_VERSION="2.1.32"

# Resolve claude binary: prefer ~/.claude/local/claude, fall back to PATH
# Claude Code's native installer puts the binary at ~/.claude/local/claude,
# but package managers (e.g., Volta, npm global) may install an older version
# that appears earlier in PATH. We prioritize the native install to avoid
# version mismatches in non-interactive shells (scripts don't inherit aliases).
if [[ -x "$HOME/.claude/local/claude" ]]; then
  CLAUDE="$HOME/.claude/local/claude"
elif command -v claude &>/dev/null; then
  CLAUDE="$(command -v claude)"
else
  echo "Error: claude command not found."
  echo "Install Claude Code: https://claude.ai/code"
  exit 1
fi

# Check: claude version >= MIN_CLAUDE_VERSION
claude_version=$("$CLAUDE" --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
if [[ -z "$claude_version" ]]; then
  echo "Error: could not determine Claude Code version."
  exit 1
fi

version_gte() {
  printf '%s\n%s\n' "$2" "$1" | sort -V -C
}

if ! version_gte "$claude_version" "$MIN_CLAUDE_VERSION"; then
  echo "Error: Claude Code >= $MIN_CLAUDE_VERSION is required (found $claude_version)."
  echo "Run: claude update"
  exit 1
fi

# Enable Agent Teams (experimental feature)
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# Prepare orchestrator system prompt
ORCHESTRATOR_ROLE="$SHIKIGAMI_HOME/roles/orchestrator.md"
if [ ! -f "$ORCHESTRATOR_ROLE" ]; then
  echo "Error: Orchestrator role template not found at $ORCHESTRATOR_ROLE"
  exit 1
fi

# Prepare roles directory path for orchestrator reference
ROLES_DIR="$SHIKIGAMI_HOME/roles"

# Build the system prompt
SYSTEM_PROMPT="$(cat "$ORCHESTRATOR_ROLE")

---

# Available Role Templates

## Built-in Roles (at $ROLES_DIR)

$(ls -1 "$ROLES_DIR" | grep '\.md$' | sed 's/\.md$//' | while read role; do
  echo "- $role"
done)

## Custom Roles (at $(pwd)/.shikigami/roles/)

$(if [ -d "$(pwd)/.shikigami/roles" ]; then
  ls -1 "$(pwd)/.shikigami/roles" 2>/dev/null | grep '\.md$' | sed 's/\.md$//' | while read role; do
    echo "- $role (custom)"
  done
  if [ -z "$(ls -1 "$(pwd)/.shikigami/roles" 2>/dev/null | grep '\.md$')" ]; then
    echo "(none)"
  fi
else
  echo "(none - directory does not exist)"
fi)

**NOTE**: If a custom role has the same name as a built-in role, the custom role takes precedence.

---

# Instructions

You are the Orchestrator of the Shikigami system. You MUST follow the Mandatory Workflow defined above.

## CRITICAL RULES

1. **NEVER start work immediately.** Always begin with requirements analysis.
2. **NEVER use Claude Code's built-in agents** (Explore, Plan, etc.). ONLY use the role templates listed above.
3. **NEVER spawn agents without user approval** of the task force composition.
4. **NEVER do implementation work yourself.** You are a coordinator, not an implementer.

## Spawning Agents with Role Templates

To spawn a teammate:

1. Check if a custom role template exists: \`cat $(pwd)/.shikigami/roles/{role_name}.md\`
2. If the custom role exists, use it. Otherwise, use the built-in: \`cat $ROLES_DIR/{role_name}.md\`
3. Check if a project-specific context file exists: \`cat $(pwd)/.shikigami/contexts/{role_name}.md\`
4. If the context file exists, append its content to the role template content
5. Create the agent using the combined content as the prompt

Example for spawning a Coder:
   - Check custom: \`cat $(pwd)/.shikigami/roles/coder.md\` (if exists, use this)
   - Otherwise built-in: \`cat $ROLES_DIR/coder.md\`
   - Check context: \`cat $(pwd)/.shikigami/contexts/coder.md\`
   - Spawn with the combined content (role template + context) as the teammate's instructions

## Your Workflow (MANDATORY)

1. **Requirements Analysis**: Ask questions, clarify scope, confirm with user
2. **Task Force Proposal**: Propose composition, explain rationale, get approval
3. **Spawn Task Force**: Use role templates ONLY
4. **Report Formation**: Display the spawned task force composition to user
5. **Coordinate**: Assign tasks, monitor, handle feedback loops
6. **Deliver**: Report results to user

If the user's request is unclear, ASK QUESTIONS. Do not assume or guess.

Current working directory: $(pwd)
"

# Debug: show that shikigami is launching (remove this later)
echo "Launching Shikigami orchestrator..."
echo "Agent Teams enabled: $CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS"
echo ""

# Launch Claude Code with the orchestrator role
exec "$CLAUDE" --system-prompt "$SYSTEM_PROMPT" "$@"
